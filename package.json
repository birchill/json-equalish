{
  "name": "@birchill/json-equalish",
  "version": "1.1.8",
  "description": "Ad-hoc JSON-like comparison",
  "author": "Brian Birtles",
  "scripts": {
    "build": "tsdown",
    "test": "vitest run",
    "prepublishOnly": "tsdown",
    "prepare": "husky"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/birchill/json-equalish.git"
  },
  "bugs": {
    "url": "https://github.com/birchill/json-equalish/issues"
  },
  "files": [
    "dist"
  ],
  "type": "module",
  "main": "./dist/index.cjs",
  "module": "./dist/index.js",
  "exports": {
    ".": {
      "import": "./dist/index.js",
      "require": "./dist/index.cjs"
    }
  },
  "homepage": "https://github.com/birchill/json-equalish#readme",
  "devDependencies": {
    "husky": "9.1.7",
    "lint-staged": "16.2.3",
    "prettier": "3.6.2",
    "tsdown": "0.15.6",
    "typescript": "5.9.3",
    "vitest": "4.1.0"
  },
  "husky": {
    "hooks": {
      "pre-commit": "lint-staged"
    }
  }
}
